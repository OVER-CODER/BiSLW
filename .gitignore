# ============================================
# Project-specific exclusions
# ============================================

# Large cache files (precomputed latents)
cache/*.pt
cache/*.pth

# Model checkpoints (too large for git)
*.pt
*.pth
results/*/
!results/.gitkeep

# Best results folder (contains large model files)
best res/*/
!best res/README.md

# Training logs
*.log
training_output.log

# Temporary files
*.tmp
*.temp
